  m_GameObject: {fileID: 853381688}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b><color=#3C060B>Winged Food Creatures: Kitchen Protocol</color></b>\r\n\r\n<b>Step
    1 \u2013 Catch ingredients</b>\r\nWinged Food Creatures are floating in the kitchen
    like they don\u2019t belong here. Grab them before they decide to leave.\r\n\r\n<b>Step
    2 \u2013 Put into the pot</b>\r\nDrop them into the pot. Everything looks normal\u2026
    which is usually a bad sign.\r\n\r\n<b>Step 3 \u2013 Turn on the heat</b>\r\nStove
    gets activated. Too late to go back.\r\n\r\n<b>Step 4 \u2013 SURPRISE</b>\r\nNot
    food anymore\u2026 more like a riddle:\r\n\r\nI have no legs but I jump when
    I\u2019m scared  \r\nI live in heat but hate it  \r\nI only calm down when everything
    stops moving  \r\nIf you shake me too much\u2026 I disappear  \r\n\r\nGuess what
    I am\u2026 or just survive it.\r\n\r\n<b>Step 5 \u2013 Control the situation</b>\r\nIf
    something goes wrong\u2026 it gets fun (for everyone except you).\r\n\r\n<b>Step
    6 \u2013 Finally</b>\r\nTransform into a surprising cooked result (nobody knows
    what it will turn into)"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
